# Environment Variables — Empathy Engine

# ─────────────────────────────────────────────────
# No API keys required for core functionality!
# gTTS uses Google's free TTS service (internet needed)
# pyttsx3 works completely offline
# HuggingFace model downloads automatically (~80MB)
# ─────────────────────────────────────────────────

# Optional: Set to 'true' to force offline pyttsx3 mode
FORCE_OFFLINE=false
